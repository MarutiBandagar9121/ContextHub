
APP_NAME = "contexthub_auth_service"
APP_VERSION = "0.1.0"

JWT_SECRET_KEY = "your_secret_key"
JWT_ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 30
REFRESH_TOKEN_EXPIRE_DAYS = 7

# Set to false for local HTTP development - browsers won't send Secure cookies over plain http.
COOKIE_SECURE = true

DATABASE_URL = "postgresql://user:password@localhost:5432/auth_db"